{
  "name": "cashenza",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "web:dev": "remix vite:dev --host 0.0.0.0",
    "start": "remix-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma",
    "shopify": "shopify"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@remix-run/node": "^2.17.0",
    "@remix-run/react": "^2.17.0",
    "@remix-run/serve": "^2.17.0",
    "@shopify/app-bridge-react": "^4.2.6",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-remix": "^4.2.0",
    "@shopify/shopify-app-session-storage-prisma": "^7.0.0",
    "isbot": "^5.1.31",
    "prisma": "6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.0",
    "@shopify/cli": "^3.85.5",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=20.10"
  }
