SHOPIFY_API_KEY="replace_me"
SHOPIFY_API_SECRET="replace_me"
# Shopify CLI injects SHOPIFY_APP_URL during `shopify app dev`.
# Set this only in production/staging when you have a fixed app URL.
# SHOPIFY_APP_URL="https://your-app.example.com"
SCOPES="read_products,write_products,read_discounts,write_discounts,read_customers,read_markets,read_orders,write_app_proxy"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
BILLING_TEST="true"
